# --- Models (multi-GB, NEVER commit) ---
*.gguf
*.bin
*.safetensors

# --- Profiler output (large; keep summaries in the writeup, not raw captures) ---
# These live under results/ next to CSVs but are ignored by extension.
*.nsys-rep
*.ncu-rep
*.qdrep
*.sqlite
results/nsys_*
results/ncu_*

# --- C/C++ build artifacts ---
build/
*.o
*.obj
*.so
*.a

# --- Python (charting / analysis) ---
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/

# --- Editor / OS ---
.vscode/
.idea/
*.swp
.DS_Store

# --- Local scratch ---
*.tmp
*.log

# --- Tracked deliverables (explicitly NOT ignored) ---
# results/*.csv                  benchmark data
# results/*.provenance.txt       per-run model fingerprint + config
# env.md                         machine/build environment
# These are committed evidence. Do not add ignore rules that catch them.
